{
  "name": "@mukundakatta/agentsnap",
  "version": "0.1.2",
  "description": "Snapshot tests for AI agents \u2014 record tool-call traces, diff against baselines, fail CI on regressions. Zero dependencies, drops into any test runner.",
  "type": "module",
  "main": "src/index.js",
  "types": "./src/index.d.ts",
  "bin": {
    "agentsnap": "src/cli.js"
  },
  "exports": {
    ".": {
      "types": "./src/index.d.ts",
      "default": "./src/index.js"
    }
  },
  "files": [
    "src",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "test": "node --test 'test/**/*.test.js'",
    "test:examples": "node --test 'examples/**/*.test.js'",
    "test:all": "node --test 'test/**/*.test.js' 'examples/**/*.test.js'",
    "test:coverage": "c8 --reporter=text --reporter=lcov --branches=70 --lines=80 --functions=80 --statements=80 node --test 'test/**/*.test.js'"
  },
  "keywords": [
    "ai",
    "agent",
    "llm",
    "snapshot",
    "testing",
    "regression",
    "tool-use",
    "anthropic",
    "openai",
    "mcp",
    "vitest",
    "jest"
  ],
  "author": "MukundaKatta",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/MukundaKatta/agentsnap.git"
  },
  "bugs": {
    "url": "https://github.com/MukundaKatta/agentsnap/issues"
  },
  "homepage": "https://github.com/MukundaKatta/agentsnap#readme",
  "devDependencies": {
    "c8": "^10.1.3"
  }
}